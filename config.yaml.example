# hanotifications configuration
# Copy to ~/.config/hanotifications/config.yaml and edit.

# -------------------------------------------------------------------
# Home Assistant connection
# -------------------------------------------------------------------

# Base URL of your HA instance (no trailing slash)
ha_url: "http://homeassistant.local:8123"

# Long-lived access token (Profile → Security → Long-Lived Access Tokens)
ha_token: "YOUR_HA_LONG_LIVED_TOKEN"

# Set to false only if HA uses a self-signed TLS cert
ha_ssl_verify: true

# -------------------------------------------------------------------
# Webhook listener
# -------------------------------------------------------------------

# Only bind to loopback. If HA is on a different host you can use
# 0.0.0.0, but then the webhook_secret becomes critical.
host: "127.0.0.1"
port: 8765

# Secret that Home Assistant must supply when calling the webhook.
# HA can send it as:
#   Authorization: Bearer <webhook_secret>
# or as an HMAC-SHA256 signature:
#   X-HA-Signature: sha256=<hex digest of body>
#
# Leave empty ("") to disable authentication (only safe on loopback).
webhook_secret: "change-me-to-a-random-string"

# -------------------------------------------------------------------
# Notification defaults
# -------------------------------------------------------------------

# Timeout in milliseconds (0 = never expire)
default_timeout_ms: 10000

# low | normal | critical
default_urgency: "normal"

# Maximum image dimension in pixels when embedding in D-Bus payload.
# Only used when falling back to the standard notification path.
# Larger = better quality, larger D-Bus message.
max_image_px: 512

# Width in pixels of the custom image popup window.
# When an image is present and tkinter + Pillow are available, hanotifications
# shows a standalone popup at this width instead of the standard notification.
# The window appears in the bottom-right corner and auto-dismisses after
# default_timeout_ms. Click anywhere on the popup to dismiss it early.
# Set to 0 to disable the custom popup and always use the standard notification.
image_popup_width: 640

# When true, clicking a camera-snapshot popup ALSO opens the live MJPEG feed
# in an external player window (in addition to dismissing the popup).
# Auto-dismiss on timeout does not launch the player — only an explicit click.
# Only fires for notifications that include camera_entity.
live_stream_on_click: true

# External player used for the live feed. Must be on PATH. Currently hard-wired
# to mpv's CLI flags (--profile=low-latency, --include, etc.), so changing this
# only makes sense if the replacement accepts the same flags.
live_stream_player: "mpv"

# Frames-per-second hint for the MJPEG stream. MJPEG has no framerate metadata,
# so mpv defaults to 25 fps — which makes low-fps HA cameras play in
# fast-forward bursts. HA's camera_proxy_stream is typically ~2 fps. Raise for
# faster cameras (e.g. Frigate, some MJPEG IP cams); if playback still runs
# ahead of real time, lower this.
live_stream_fps: 2

# -------------------------------------------------------------------
# System tray icon (KDE / Plasma)
# -------------------------------------------------------------------

# When true, show a Home Assistant icon in the system tray.
# The icon is blue when the HA server is reachable and grey when it is not.
# Requires python-pyqt6 (installed by install.sh).
system_tray: false

# Seconds between HA reachability checks used to color the tray icon.
ha_check_interval_s: 30

# Inbound heartbeat: when true, the tray also goes grey if Home Assistant
# has not POSTed to /heartbeat within heartbeat_grace_s seconds. This catches
# failures the outbound check can't — e.g. HA is up but can no longer reach
# this host (firewall change, daemon host moved, HA automation broken).
#
# Requires an HA automation that calls the hanotifications_heartbeat
# rest_command every 60 seconds. See ha_examples/ for a ready-to-paste
# configuration. Leave false if you haven't set that up.
heartbeat_required: false

# Maximum age (seconds) of the last heartbeat before the link is considered
# stale. The default 90s pairs with a 60s HA cadence and tolerates one miss.
heartbeat_grace_s: 90
